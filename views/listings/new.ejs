<% layout("/layouts/boilerplate") %>
<h3>Create a New Listing</h3>
<br>
<div class="row mt-3">
<div class="col-8 offset-2">

<form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data" >
      <div class="md-3">
      <label for="title" class="form-label"> Enter title</label>
      <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required />
      <div class="valid-feedback">Title looks good</div>
      </div>
      <div class="md-3">
        <label for="description" class="form-label" required> Enter description</label>
      <textarea
        name="listing[description]"
        placeholder="enter description"
        class="form-control" required>
      </textarea>
      </div>

      <div class="md-3">
        <label for="image" class="form-label" > Upload image</label>
        <input
        name="listing[image]"
        type="file"
        class="form-control"
        required
      />
      </div>

      <div class="row">

      <div class="md-3 col-md-4">
        <label for="price" class="form-label"> Enter price</label>
         <input name="listing[price]" placeholder="enter price" type="number" class="form-control" required/>
         <div class="invalid-feedback">Please enter a valid price</div>
      </div>
     
      <div class="md-3 col-md-8">
         <label for="country" class="form-label"> Enter country</label>
        <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required />
        <div class="invalid-feedback">Please enter a valid country name</div>
      </div>
      </div>
      
  <div class="md-3">
     <label for="location" class="form-label"> Enter location</label>
     <input
        name="listing[location]"
        placeholder="enter location"
        type="text"
        class="form-control"
        required
      />
      <div class="invalid-feedback">Please enter a valid location</div>
  </div>

      <button class="btn btn-dark add-btn mt-3">Add</button>

</form>
</div>
</div>